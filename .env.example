# ─────────────────────────────────────────────────────────────
# Cloud Incident Lab — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=incidentlab
POSTGRES_USER=incidentuser
POSTGRES_PASSWORD=changeme

# JDBC URL used by the Spring Boot backend
# Note: inside Docker, services talk to each other on port 5432 (internal).
# Host machine connects on 5433 to avoid conflict with a local Postgres install.
DB_URL=jdbc:postgresql://postgres:5432/incidentlab
DB_USER=incidentuser
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Backend API ───────────────────────────────────────────────
BACKEND_PORT=8080

# ── Frontend ──────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8080
